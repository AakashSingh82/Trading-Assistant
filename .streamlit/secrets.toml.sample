# Streamlit Cloud -> App -> Settings -> Secrets : paste this block, filled in.
# (For LOCAL runs you can also create .streamlit/secrets.toml with the same
#  content, but DO NOT commit the real one — it's gitignored.)
[kotak]
consumer_key  = "PASTE_YOUR_TOKEN_HERE"
mobile_number = "+91XXXXXXXXXX"
ucc           = "YOUR_UCC_CODE"
mpin          = "YOUR_6_DIGIT_MPIN"
# TOTP is NOT stored here — you type it in the sidebar each session.
